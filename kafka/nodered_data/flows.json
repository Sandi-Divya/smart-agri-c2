    {
        "id": "map_c1_to_schema",
        "type": "function",
        "z": "58537460369eabf7",
        "name": "Map C1 to Schema",
        "func": "const topic = msg.topic;\nconst value = parseFloat(msg.payload);\n\n// Map C1 topic to our parameter name\nconst topicMap = {\n    'zone1/sensors/temperature': 'ambient_temp',\n    'zone1/sensors/humidity': 'humidity',\n    'zone1/sensors/pressure': 'pressure',\n    'zone1/sensors/soil_moisture': 'soil_moisture'\n};\n\nconst parameter = topicMap[topic];\n\n// Skip topics we don't need\nif (!parameter) return null;\n\nfunction getUnit(param) {\n    const units = {\n        'ambient_temp': 'C',\n        'humidity': '%',\n        'pressure': 'hPa',\n        'soil_moisture': '%'\n    };\n    return units[param] || '';\n}\n\n// Build our standard schema\nmsg.payload = {\n    device_id: 'esp32-c1-01',\n    field_id: 'field1',\n    timestamp: new Date().toISOString(),\n    parameter: parameter,\n    value: value,\n    unit: getUnit(parameter)\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 500,
        "wires": [
            [
                "b09ba8387fab3615"
            ]
        ]
    },
    {
        "id": "b09ba8387fab3615",
        "type": "function",
        "z": "58537460369eabf7",
        "name": "Validate & Route",
        "func": "const required = ['device_id', 'field_id', 'timestamp', 'parameter', 'value', 'unit'];\nconst missing = required.filter(k => \n    msg.payload[k] === undefined || \n    msg.payload[k] === null || \n    msg.payload[k] === ''\n);\n\nif (missing.length > 0) {\n    msg.topic = 'sensor.dlq';\n    msg.payload = { \n        ...msg.payload, \n        error: 'Missing fields: ' + missing.join(', '), \n        dlq_at: new Date().toISOString() \n    };\n    return [null, null, msg, msg];\n}\n\nconst topicMap = {\n    'soil_moisture': 'sensor.soil_moisture',\n    'soil_temp': 'sensor.soil_temp',\n    'ambient_temp': 'sensor.ambient_temp',\n    'humidity': 'sensor.humidity',\n    'pressure': 'sensor.pressure',\n    'solar_radiation': 'sensor.solar_radiation'\n};\n\nmsg.topic = topicMap[msg.payload.parameter] || 'sensor.dlq';\nmsg.payload = JSON.stringify(msg.payload);\nreturn [msg, msg, null, null];",
        "outputs": 4,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
